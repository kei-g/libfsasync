{
  "author": {
    "email": "km.8k6ce+npm@gmail.com",
    "name": "kei-g"
  },
  "bugs": {
    "url": "https://github.com/kei-g/libfsasync/issues"
  },
  "description": "Async fs Library",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.6.0",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  },
  "keywords": [
    "Promise",
    "async",
    "fs",
    "library"
  ],
  "homepage": "https://github.com/kei-g/libfsasync",
  "license": "BSD-3-Clause",
  "main": "index.js",
  "name": "libfsasync",
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "github:kei-g/libfsasync",
  "scripts": {
    "build": "npm-run-all2 --parallel build:*",
    "build:bundle": "esbuild src/index.ts --bundle --format=cjs --minify --outfile=index.js --platform=node --target=ES2015",
    "build:tsc": "tsc",
    "clean": "rimraf coverage/ index.d.ts index.js lib/",
    "cover": "npm-run-all2 --sequential cover:clean cover:check cover:clean",
    "cover:check": "c8 node --test",
    "cover:clean": "rimraf tmp/",
    "lint": "biome lint --write",
    "postbuild:tsc": "tar -C types/src -cf - . | tar -xf - && rm -fr types",
    "postpublish": "npm run clean",
    "prebuild": "npm-run-all2 --parallel clean lint",
    "prepublishOnly": "npm run build",
    "test": "npm-run-all2 --parallel cover lint"
  },
  "type": "module",
  "types": "index.d.ts",
  "version": "1.0.16"
}
